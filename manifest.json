{
  "manifest_version": 3,
  "name": "Prompt Polisher",
  "version": "1.1.0",
  "description": "Standalone professional prompt engineer powered by Gemini.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ]
}
